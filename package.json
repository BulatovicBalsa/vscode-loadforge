{
  "name": "loadforge",
  "displayName": "LoadForge",
  "description": "Load test using simple description language",
  "publisher": "siit-na-kvadrat",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "loadforge.runLoadTest",
        "title": "Run Load Test",
        "icon": "$(play)"
      },
      {
        "command": "loadforge.stopLoadTest",
        "title": "Stop Load Test",
        "icon": "$(stop)"
      }
    ],
    "languages": [
      {
        "id": "lf-dsl",
        "extensions": [
          ".lf"
        ],
        "aliases": [
          "LoadForge DSL",
          "lf-dsl"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "icons/beaker-light.svg",
          "dark": "icons/beaker-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "lf-dsl",
        "scopeName": "source.lf-dsl",
        "path": "./syntaxes/lf-dsl.tmLanguage.json"
      }
    ],
    "keybindings": [
      {
        "command": "loadforge.runLoadTest",
        "key": "F5",
        "when": "editorLangId == 'lf-dsl' && !loadforge.isRunning"
      },
      {
        "command": "loadforge.stopLoadTest",
        "key": "F5",
        "when": "editorLangId == 'lf-dsl' && loadforge.isRunning"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "loadforge.runLoadTest",
          "when": "editorLangId == 'lf-dsl' && !loadforge.isRunning"
        },
        {
          "command": "loadforge.stopLoadTest",
          "when": "editorLangId == 'lf-dsl' && loadforge.isRunning"
        }
      ],
      "explorer/context": [
        {
          "command": "loadforge.runLoadTest",
          "when": "resourceLangId == 'lf-dsl' && !loadforge.isRunning",
          "group": "navigation"
        },
        {
          "command": "loadforge.stopLoadTest",
          "when": "resourceLangId == 'lf-dsl' && loadforge.isRunning",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "loadforge.runLoadTest",
          "when": "editorLangId == 'lf-dsl' && !loadforge.isRunning",
          "group": "navigation"
        },
        {
          "command": "loadforge.stopLoadTest",
          "when": "editorLangId == 'lf-dsl' && loadforge.isRunning",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "loadforge.runLoadTest",
          "when": "editorLangId == 'lf-dsl' && !loadforge.isRunning",
          "group": "navigation"
        },
        {
          "command": "loadforge.stopLoadTest",
          "when": "editorLangId == 'lf-dsl' && loadforge.isRunning",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "panel": [
        {
          "id": "loadforge-panel",
          "title": "LoadForge",
          "icon": "$(beaker)"
        }
      ]
    },
    "views": {
      "loadforge-panel": [
        {
          "id": "loadforge-output",
          "name": "Output",
          "icon": "$(beaker)",
          "type": "webview"
        }
      ]
    },
    "snippets": [
      {
        "language": "lf-dsl",
        "path": "./snippets/snippets.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "ansi-to-html": "^0.7.2"
  }
}
